{
  "name": "@openclaw/copy",
  "version": "0.1.0",
  "description": "OpenClaw Copy channel plugin — voice messaging via the Copy walkie-talkie app",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "postinstall": "node -e \"const{cpSync,existsSync}=require('fs'),p=require('path'),src=p.join('node_modules','libsodium','dist','modules-sumo','libsodium-sumo.js'),dst=p.join('node_modules','libsodium-wrappers','dist','modules-sumo','libsodium-sumo.js');if(existsSync(src)&&!existsSync(dst)){const d=p.dirname(dst);require('fs').mkdirSync(d,{recursive:true});cpSync(src,dst)}\"",
    "register": "npx tsx src/cli/register.ts",
    "pair": "npx tsx src/cli/pair.ts",
    "status": "npx tsx src/cli/status.ts",
    "join": "npx tsx src/cli/join.ts"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "openclaw": "*",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "libsodium-wrappers": "^0.7.16",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "copy",
      "label": "Copy",
      "selectionLabel": "Copy (voice plugin)",
      "docsPath": "/channels/copy",
      "docsLabel": "copy",
      "blurb": "async voice messaging via Copy walkie-talkie app; audio encrypted end-to-end with libsodium.",
      "order": 90,
      "quickstartAllowFrom": false
    },
    "install": {
      "localPath": ".",
      "defaultChoice": "local"
    }
  }
}
